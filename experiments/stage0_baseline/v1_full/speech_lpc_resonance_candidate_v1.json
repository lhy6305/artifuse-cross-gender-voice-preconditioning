      "confidence": "diagnostic",
      "priority": 99,
      "method_family": "lpc_residual_preserving_pole_edit",
      "method_params": {
        "frame_length": 1024,
        "hop_length": 256,
        "lpc_order": 16,
        "search_ranges_hz": [
          [280.0, 1000.0],
          [1000.0, 2700.0],
          [2700.0, 4400.0]
        ],
        "shift_ratios": [0.87, 0.91, 0.95],
        "blend": 0.78
      },
      "notes": "LPC masculine 侧：VCTK 稍宽一档，先优先确认是不是比 formant-anchor 更容易跨过可感知阈值。"
    }
  ]
