{
  "config_version": "stage0_speech_rule_candidate_v1",
  "source": "fixed_eval_review_final_v1_2.csv speech diagnostic listening pack",
  "selection_policy": {
    "domain": "speech_only",
    "group_axis": "dataset_name",
    "source_pool": "fixed_eval_v1_2 reviewed usable speech rows",
    "source_gender_to_target_direction": {
      "male": "feminine",
      "female": "masculine"
    },
    "purpose": "audibility_diagnostic_not_final_directional_rule"
  },
  "strength_presets": {
    "diagnostic_high": {
      "alpha_default": 0.75,
      "alpha_max": 1.0
