      "action_family": "brightness_down",
      "strength": {
        "label": "diagnostic_envwarp",
        "alpha_default": 1.0,
        "alpha_max": 1.0
      },
      "confidence": "diagnostic",
      "priority": 50,
      "method_family": "voiced_envelope_warp",
      "method_params": {
