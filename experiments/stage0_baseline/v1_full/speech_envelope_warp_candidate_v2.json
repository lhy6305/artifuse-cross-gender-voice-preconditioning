{
  "config_version": "stage0_speech_envelope_warp_candidate_v2",
  "source": "speech_envelope_warp_candidate_v1 strengthened after partial audibility listening",
  "selection_policy": {
    "domain": "speech_only",
    "group_axis": "dataset_name",
    "source_gender_to_target_direction": {
      "male": "feminine",
      "female": "masculine"
    },
    "purpose": "voiced_envelope_warp_audibility_probe_v2"
  },
  "rules": [
    {
      "rule_id": "stage0_speech_envwarp_libritts_feminine_v2",
      "enabled": true,
      "match": {
        "domain": "speech",
        "group_axis": "dataset_name",
        "group_value": "LibriTTS-R",
        "f0_condition": "all",
        "f0_lower_hz": null,
        "f0_upper_hz": null,
        "bucket_scheme": "all"
      },
      "signal_name": "speech_envelope_warp_probe",
      "target_direction": "feminine",
      "action_family": "brightness_up",
      "strength": {
        "label": "diagnostic_envwarp_v2",
        "alpha_default": 1.0,
        "alpha_max": 1.0
      },
      "confidence": "diagnostic",
      "priority": 60,
      "method_family": "voiced_envelope_warp",
      "method_params": {
        "warp_factor": 1.18,
        "blend": 0.95,
        "envelope_smooth_bins": 25,
        "max_envelope_gain_db": 8.0,
        "voiced_rms_gate_db": 36.0
      },
      "notes": "v2: feminine 侧加大上移与 blend，优先补强此前 mostly-maybe 的样本。"
    },
    {
      "rule_id": "stage0_speech_envwarp_vctk_feminine_v2",
      "enabled": true,
      "match": {
        "domain": "speech",
        "group_axis": "dataset_name",
        "group_value": "VCTK Corpus 0.92",
        "f0_condition": "all",
        "f0_lower_hz": null,
        "f0_upper_hz": null,
        "bucket_scheme": "all"
      },
      "signal_name": "speech_envelope_warp_probe",
      "target_direction": "feminine",
      "action_family": "brightness_up",
      "strength": {
        "label": "diagnostic_envwarp_v2",
        "alpha_default": 1.0,
        "alpha_max": 1.0
      },
      "confidence": "diagnostic",
      "priority": 59,
      "method_family": "voiced_envelope_warp",
      "method_params": {
        "warp_factor": 1.14,
        "blend": 0.92,
        "envelope_smooth_bins": 25,
        "max_envelope_gain_db": 7.0,
        "voiced_rms_gate_db": 36.0
      },
      "notes": "v2: VCTK feminine 侧也补强，但仍略低于 LibriTTS-R。"
    },
    {
      "rule_id": "stage0_speech_envwarp_libritts_masculine_v2",
      "enabled": true,
      "match": {
        "domain": "speech",
        "group_axis": "dataset_name",
        "group_value": "LibriTTS-R",
        "f0_condition": "all",
        "f0_lower_hz": null,
        "f0_upper_hz": null,
        "bucket_scheme": "all"
      },
      "signal_name": "speech_envelope_warp_probe",
      "target_direction": "masculine",
      "action_family": "brightness_down",
      "strength": {
        "label": "diagnostic_envwarp_v2",
        "alpha_default": 1.0,
        "alpha_max": 1.0
      },
      "confidence": "diagnostic",
      "priority": 60,
      "method_family": "voiced_envelope_warp",
      "method_params": {
        "warp_factor": 0.86,
        "blend": 0.93,
        "envelope_smooth_bins": 25,
        "max_envelope_gain_db": 8.0,
        "voiced_rms_gate_db": 36.0
      },
      "notes": "v2: LibriTTS-R masculine 侧已有部分可感知，只做中等上调，避免过推。"
    },
    {
      "rule_id": "stage0_speech_envwarp_vctk_masculine_v2",
      "enabled": true,
      "match": {
        "domain": "speech",
        "group_axis": "dataset_name",
