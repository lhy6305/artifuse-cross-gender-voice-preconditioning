# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Python cache / local env
__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
.venv/
venv/
env/

# Local runtime artifacts
tmp/
scratch/
*.log
!tmp/
tmp/*
!tmp/.gitkeep

# Sensitive local auth and push helpers
ssh-*
git-*.bat
git-*.sh

# Local third-party worktrees / bundled runtimes
pretrained_rvc_firefly_fp32/
Retrieval-based-Voice-Conversion-WebUI-7ef1986/
external_models/
python.exe
pythonw.exe
codex_perm_cleanup_static.exe
*.dll

# Optional large local caches
*.npy
*.npz

# Model artifacts stay local by default; curated keepers live under artifacts/checkpoints/keep/
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.bin
*.index
!artifacts/
!artifacts/checkpoints/
!artifacts/checkpoints/keep/
!artifacts/checkpoints/keep/**

# Never publish raw or derived audio assets
*.lab
*.wav
*.mp3
*.flac
*.ogg
*.m4a
*.aac
*.wma
*.opus

# Dataset downloads and extracted raw trees stay local.
data/datasets/**/raw/
data/datasets/**/*.zip
data/datasets/**/*.7z
data/datasets/**/*.tar
data/datasets/**/*.tar.gz
data/datasets/**/*.tgz
data/datasets/**/*.gz
data/datasets/**/*.xz
data/datasets/**/*.rar

# Structured dataset metadata stays in Git.
!data/datasets/_meta/
!data/datasets/_meta/**
